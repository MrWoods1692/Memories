<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Memories Server - 运行中"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- FRPC 配置区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FRPC 内网穿透配置"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="frpc 可执行文件路径"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/edit_frpc_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="/data/local/tmp/frpc"
            android:inputType="text"
            android:singleLine="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="frpc.ini 配置内容"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/edit_frpc_config"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:hint="[common]\nserver_addr = your-server.com\nserver_port = 7000\ntoken = your-token\n\n[memories-api]\ntype = tcp\nlocal_ip = 127.0.0.1\nlocal_port = 8080\nremote_port = 8080"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/text_frpc_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FRPC: 等待配置"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <!-- 服务器状态 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="服务器信息"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/text_server_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="端口: 8080 | 图片数: 0"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>
